OPENAI_MODEL=gpt-4o-mini

DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat

LLM_FALLBACK_ENABLED=true
LLM_API_KEY=
LLM_BASE_URL=
LLM_MODEL=

DATABASE_URL=sqlite:///./gh_shs.db
AUTH_DB_PATH=
AUTH_SECRET_KEY=change-this-auth-secret
ADMIN_SECRET=change-this-admin-secret
